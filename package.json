{
  "name": "azure-blob-to-s3",
  "version": "3.0.0",
  "description": "Batch copy files from Azure Blob Storage to Amazon S3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bendrucker/azure-blob-to-s3.git"
  },
  "author": {
    "name": "Ben Drucker",
    "email": "bvdrucker@gmail.com",
    "url": "https://www.bendrucker.me"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "azure-s3": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --test src/*.test.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build"
  },
  "keywords": [
    "batch",
    "copy",
    "azure",
    "blob",
    "storage",
    "s3",
    "amazon",
    "aws",
    "files"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1065.0",
    "@aws-sdk/lib-storage": "^3.1065.0",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.32.0",
    "meow": "^14.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "aws-sdk-client-mock": "^4.1.0",
    "eslint": "^10.4.1",
    "neostandard": "^0.13.0",
    "typescript": "^6.0.3"
  }
}
